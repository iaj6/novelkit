# Copy this to .env and fill in the keys you need.

# Required for cdk/ (the drafter) and press/ cover-brief synthesis
ANTHROPIC_API_KEY=sk-ant-...

# Required for press/ cover-image generation and OpenAI TTS audio
OPENAI_API_KEY=sk-...

# Required for press/ ElevenLabs audiobook generation
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# --- Optional overrides ---

# Anthropic model used for cover-brief synthesis
# ANTHROPIC_COVER_MODEL=claude-sonnet-4-6

# OpenAI image model
# OPENAI_IMAGE_MODEL=gpt-image-1.5

# OpenAI TTS knobs
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy
# OPENAI_TTS_FORMAT=mp3
# OPENAI_TTS_SPEED=1.0
# OPENAI_TTS_MAX_CHARS=4500

# ElevenLabs TTS knobs
# ELEVENLABS_MODEL_ID=eleven_v3
# ELEVENLABS_STABILITY=0.35
# ELEVENLABS_SIMILARITY=0.75
# ELEVENLABS_STYLE=0.15
# ELEVENLABS_SPEED=1.0
