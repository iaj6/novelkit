{
  "name": "cdk",
  "version": "0.1.0",
  "description": "Claude Drafting Kit — autonomously draft books from a markdown brief",
  "type": "module",
  "private": true,
  "bin": {
    "cdk": "./bin/cdk.mjs"
  },
  "scripts": {
    "cdk": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.140",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
