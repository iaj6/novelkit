# build output
dist/
# generated types
.astro/

# Book artifacts live under public/books/ — these ARE tracked
# (they're the deployed source of truth, populated by sync-library.sh
# from the gitignored library/<slug>/build/ workshop output).
#
# INVARIANT: only books with visibility="public" belong here. sync-library.sh
# is visibility-aware — it skips private books and prunes any stale public/books
# copy of one. Run `npm run sync` before staging so a book flipped private is
# removed here too; don't hand-commit a private book's files under public/books.
#
# Audio is excluded — MP3s can run hundreds of MB per book and shouldn't
# bloat the repo. They're regenerable via press/build_audiobook*.sh.
public/books/*/audiobook/
public/books/*/audiobook-openai/
public/books/*/tts/
# Cover prompts are useful locally but not for the deployed site.
public/books/*/cover-prompt.md

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
