---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookCard from "../components/BookCard.astro";
import Ornament from "../components/Ornament.astro";
import { getBooks } from "../lib/library";

const books = getBooks();
---

<BaseLayout title="lantern & page">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="vol-label small-caps reveal reveal-1">vol. i &middot; the inaugural shelf</p>
        <h1 class="hero-title reveal reveal-2">
          <span class="line"><em>lantern</em></span>
          <span class="line ampline">&amp;</span>
          <span class="line"><em>page</em></span>
        </h1>
        <p class="hero-lede reveal reveal-3">
          a small press of novels drafted, autonomously, by AI agents.
          one human writes a brief. everything else &mdash; the canon,
          the outline, the chapters, the cover, the audiobook &mdash;
          is produced by the agents from there.
        </p>
        <p class="hero-aside meta reveal reveal-4">
          this is a reading room, not a bookstore. nothing is for sale.
          read what you like; download what you want.
        </p>
      </div>
      <div class="hero-figure reveal reveal-3" aria-hidden="true">
        <div class="hero-lantern">
          <svg viewBox="0 0 240 360" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="glow" cx="50%" cy="50%" r="55%">
                <stop offset="0%" stop-color="#C99A4A" stop-opacity="0.50" />
                <stop offset="55%" stop-color="#C99A4A" stop-opacity="0.10" />
                <stop offset="100%" stop-color="#C99A4A" stop-opacity="0" />
              </radialGradient>
            </defs>

            <circle cx="120" cy="180" r="135" fill="url(#glow)" />

            <line x1="120" y1="38" x2="120" y2="68" stroke="#5C4F40" stroke-width="2" stroke-linecap="round" />
            <ellipse cx="120" cy="70" rx="22" ry="6" stroke="#4A3F35" stroke-width="2" fill="#ECE0CA" />
            <path d="M88 80 Q120 70 152 80 L142 100 Q120 92 98 100 Z"
                  fill="#806E5D" stroke="#4A3F35" stroke-width="1.8" stroke-linejoin="round" />
            <line x1="98" y1="102" x2="95" y2="262" stroke="#4A3F35" stroke-width="2" stroke-linecap="round" />
            <line x1="142" y1="102" x2="145" y2="262" stroke="#4A3F35" stroke-width="2" stroke-linecap="round" />
            <line x1="98" y1="104" x2="142" y2="104" stroke="#4A3F35" stroke-width="2" />
            <line x1="95" y1="262" x2="145" y2="262" stroke="#4A3F35" stroke-width="2" />
            <rect x="100" y="106" width="42" height="156" fill="#C99A4A" fill-opacity="0.08" />
            <path d="M120 140 C 108 175, 108 195, 120 215 C 132 195, 132 175, 120 140 Z"
                  fill="#C99A4A" />
            <path d="M120 158 C 114 178, 114 192, 120 205 C 126 192, 126 178, 120 158 Z"
                  fill="#F4EBD9" fill-opacity="0.7" />
            <path d="M88 262 L 92 282 L 148 282 L 152 262" stroke="#4A3F35" stroke-width="2" fill="#806E5D" stroke-linejoin="round" />
            <line x1="105" y1="284" x2="135" y2="304" stroke="#4A3F35" stroke-width="2" stroke-linecap="round" />
            <line x1="135" y1="284" x2="105" y2="304" stroke="#4A3F35" stroke-width="2" stroke-linecap="round" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <Ornament variant="rule" />

  <section class="catalogue">
    <div class="container">
      <header class="cat-head reveal reveal-2">
        <p class="small-caps">the shelf</p>
        <h2 class="cat-title">on hand, in print, in audio</h2>
        <p class="cat-lede">
          {books.length} {books.length === 1 ? "title" : "titles"} in the library.
          some published in full; some still being drafted. each began as a
          single page.
        </p>
      </header>

      <ol class="book-grid">
        {books.map((book, i) => (
          <li>
            <BookCard book={book} index={i} />
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-5);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-5);
    align-items: center;
  }

  .vol-label {
    margin-bottom: var(--space-3);
  }

  .hero-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 120, "SOFT" 80;
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--ink);
    font-size: clamp(3.4rem, 9vw, 6rem);
    margin-bottom: var(--space-3);
  }

  .hero-title .line {
    display: block;
    font-style: italic;
  }

  .hero-title .ampline {
    color: var(--lantern);
    font-style: italic;
    margin-block: -0.05em;
    padding-left: 1.4em;
    font-size: 0.85em;
  }

  .hero-lede {
    font-size: var(--size-lead);
    line-height: 1.55;
    max-width: 34rem;
    color: var(--ink-soft);
    margin-bottom: var(--space-3);
  }

  .hero-aside {
    max-width: 30rem;
    font-style: italic;
  }

  .hero-figure {
    justify-self: center;
  }

  .hero-lantern {
    width: min(280px, 100%);
    aspect-ratio: 240 / 360;
  }

  .hero-lantern svg {
    width: 100%;
    height: 100%;
  }

  .catalogue {
    padding-block: var(--space-4) var(--space-5);
  }

  .cat-head {
    margin-bottom: var(--space-5);
    max-width: 38rem;
  }

  .cat-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 60, "SOFT" 50;
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.05;
    margin-block: 0.4rem 0.9rem;
    color: var(--ink);
  }

  .cat-lede {
    color: var(--ink-soft);
    font-size: var(--size-body);
    max-width: 32rem;
  }

  .book-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5) var(--space-4);
    margin: 0;
    padding: 0;
  }

  @media (max-width: 800px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero-figure {
      order: -1;
      justify-self: start;
    }
    .hero-lantern {
      width: 180px;
    }
  }
</style>
