---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookCard from "../components/BookCard.astro";
import Ornament from "../components/Ornament.astro";
import { getBooks } from "../lib/library";

const books = getBooks();
---

<BaseLayout title="lantern & page">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="vol-label small-caps reveal reveal-1">vol. i &middot; the inaugural shelf</p>
        <h1 class="hero-title reveal reveal-2">
          <span class="line"><em>lantern</em></span>
          <span class="line ampline">&amp;</span>
          <span class="line"><em>page</em></span>
        </h1>
        <p class="hero-lede reveal reveal-3">
          a small press of novels drafted, autonomously, by AI agents.
          one human writes a brief. everything else &mdash; the canon,
          the outline, the chapters, the cover, the audiobook &mdash;
          is produced by the agents from there.
        </p>
        <p class="hero-aside meta reveal reveal-4">
          this is a reading room, not a bookstore. nothing is for sale.
          read what you like; download what you want.
        </p>
      </div>
      <figure class="hero-figure reveal reveal-3">
        <img
          src="/generated/lantern.webp"
          alt=""
          class="hero-lantern"
          aria-hidden="true"
          width="220"
          height="220"
        />
      </figure>
    </div>
  </section>

  <figure class="hero-scene reveal reveal-4" aria-label="the reading room">
    <div class="hero-scene-frame">
      <img
        src="/generated/hero.webp"
        alt="a small bookstore interior at dusk — wooden shelves, a brass lantern, an open book on a table near a window"
        width="1536"
        height="1024"
        loading="eager"
      />
    </div>
    <figcaption class="meta scene-caption">
      <em>the reading room.</em> &nbsp; lantern lit at the end of the afternoon.
    </figcaption>
  </figure>

  <Ornament variant="rule" />

  <section class="catalogue">
    <div class="container">
      <header class="cat-head reveal reveal-2">
        <p class="small-caps">the shelf</p>
        <h2 class="cat-title">on hand, in print, in audio</h2>
        <p class="cat-lede">
          {books.length} {books.length === 1 ? "title" : "titles"} in the library.
          some published in full; some still being drafted. each began as a
          single page.
        </p>
      </header>

      <ol class="book-grid">
        {books.map((book, i) => (
          <li>
            <BookCard book={book} index={i} />
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-5);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-5);
    align-items: center;
  }

  .vol-label {
    margin-bottom: var(--space-3);
  }

  .hero-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 120, "SOFT" 80;
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--ink);
    font-size: clamp(3.4rem, 9vw, 6rem);
    margin-bottom: var(--space-3);
  }

  .hero-title .line {
    display: block;
    font-style: italic;
  }

  .hero-title .ampline {
    color: var(--lantern);
    font-style: italic;
    margin-block: -0.05em;
    padding-left: 1.4em;
    font-size: 0.85em;
  }

  .hero-lede {
    font-size: var(--size-lead);
    line-height: 1.55;
    max-width: 34rem;
    color: var(--ink-soft);
    margin-bottom: var(--space-3);
  }

  .hero-aside {
    max-width: 30rem;
    font-style: italic;
  }

  .hero-figure {
    justify-self: center;
    margin: 0;
  }

  .hero-lantern {
    width: clamp(180px, 22vw, 280px);
    height: auto;
    mix-blend-mode: multiply;     /* lantern PNG cream blends into paper */
    filter: drop-shadow(0 22px 28px rgba(28, 20, 15, 0.10));
  }

  /* ── hero scene banner ─────────────────────────────────────── */

  .hero-scene {
    margin: var(--space-5) auto 0;
    width: min(76rem, 100% - 1.5rem);
  }

  .hero-scene-frame {
    aspect-ratio: 3 / 2;
    border: 1px solid var(--paper-edge);
    box-shadow: var(--shadow-page);
    overflow: hidden;
    background: var(--paper-deep);
  }

  .hero-scene img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .scene-caption {
    margin-top: 0.85rem;
    text-align: center;
    font-style: italic;
    letter-spacing: 0.005em;
    color: var(--ink-faded);
  }

  .scene-caption em {
    color: var(--ink-soft);
    font-style: italic;
  }

  .catalogue {
    padding-block: var(--space-4) var(--space-5);
  }

  .cat-head {
    margin-bottom: var(--space-5);
    max-width: 38rem;
  }

  .cat-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 60, "SOFT" 50;
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.05;
    margin-block: 0.4rem 0.9rem;
    color: var(--ink);
  }

  .cat-lede {
    color: var(--ink-soft);
    font-size: var(--size-body);
    max-width: 32rem;
  }

  .book-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5) var(--space-4);
    margin: 0;
    padding: 0;
  }

  @media (max-width: 800px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero-figure {
      order: -1;
      justify-self: start;
    }
    .hero-lantern {
      width: 180px;
    }
  }
</style>
