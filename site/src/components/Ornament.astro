---
/**
 * A small inline lantern silhouette used between sections. Hand-drawn
 * SVG — a hanging cylindrical lantern with a single flame mark.
 *
 * Props:
 *   variant: "single" | "rule" — rule version adds hairlines on either side
 *   size: pixel height (default 28)
 */
interface Props {
  variant?: "single" | "rule";
  size?: number;
}

const { variant = "single", size = 28 } = Astro.props;
---

<div class={`ornament ornament-${variant}`} role="presentation" aria-hidden="true">
  {variant === "rule" && <span class="rule" />}
  <svg
    width={size}
    height={Math.round(size * 1.55)}
    viewBox="0 0 30 46"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    {/* Hanger */}
    <line x1="15" y1="0" x2="15" y2="4" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
    {/* Top ring */}
    <ellipse cx="15" cy="6" rx="3.5" ry="1.3" stroke="currentColor" stroke-width="1" fill="none" />
    {/* Cap */}
    <path
      d="M9 9 Q15 7 21 9 L19.5 12 Q15 11 10.5 12 Z"
      stroke="currentColor"
      stroke-width="1"
      fill="none"
      stroke-linejoin="round"
    />
    {/* Frame uprights */}
    <line x1="10" y1="13" x2="9" y2="35" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
    <line x1="20" y1="13" x2="21" y2="35" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
    {/* Frame crosspieces */}
    <line x1="9" y1="35" x2="21" y2="35" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
    <line x1="9.5" y1="14" x2="20.5" y2="14" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" />
    {/* Flame */}
    <path
      d="M15 19 C 13.4 22, 13.4 24, 15 26 C 16.6 24, 16.6 22, 15 19 Z"
      fill="currentColor"
      opacity="0.86"
    />
    {/* Base */}
    <path
      d="M11 35 L 12 39 L 18 39 L 19 35"
      stroke="currentColor"
      stroke-width="1"
      fill="none"
      stroke-linejoin="round"
    />
    <line x1="13.5" y1="39" x2="16.5" y2="41" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" />
  </svg>
  {variant === "rule" && <span class="rule" />}
</div>

<style>
  .ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lantern);
  }

  .ornament-rule {
    gap: 1.25rem;
    margin-block: var(--space-5);
  }

  .ornament-single {
    margin-block: var(--space-4);
  }

  .rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right,
      transparent 0%,
      var(--rule) 18%,
      var(--rule) 82%,
      transparent 100%);
    max-width: 220px;
  }

  svg {
    display: block;
  }
</style>
