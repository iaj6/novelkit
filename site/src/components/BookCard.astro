---
import type { Book } from "../lib/library";
import { artifactUrl } from "../lib/library";

interface Props {
  book: Book;
  index?: number;
}

const { book, index = 0 } = Astro.props;

// Prefer the WebP thumbnail (~50KB) for the grid; fall back to the full
// WebP, then the PNG.
const coverFile =
  book.artifacts.coverThumb ??
  book.artifacts.coverWebp ??
  book.artifacts.cover ??
  null;
const coverUrl = coverFile ? artifactUrl(book.slug, coverFile) : null;
const isComplete = book.status === "complete";
const revealClass = `reveal reveal-${Math.min((index % 5) + 1, 5)}`;
---

<article class={`book-card ${revealClass}`}>
  <a href={`/book/${book.slug}/`} class="card-link" aria-label={`open ${book.title}`}>
    <div class="cover-frame">
      {coverUrl ? (
        <img src={coverUrl} alt={`cover of ${book.title}`} class="cover" loading="lazy" />
      ) : (
        <div class="cover cover-placeholder" aria-hidden="true">
          <div class="cover-title">{book.title}</div>
          <div class="cover-meta">[ cover pending ]</div>
        </div>
      )}
      {!isComplete && (
        <span class={`status status-${book.status}`}>
          {book.status === "draft" ? "brief only" : "in progress"}
        </span>
      )}
    </div>
    <div class="meta-block">
      <h2 class="title">{book.title}</h2>
      {book.oneLine && <p class="one-line">{book.oneLine}</p>}
      <span class="open-link">read &rarr;</span>
    </div>
  </a>
</article>

<style>
  .book-card {
    position: relative;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border: 0;
    color: inherit;
    transition: transform 380ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .card-link:hover {
    transform: translateY(-3px);
  }

  .cover-frame {
    position: relative;
    aspect-ratio: 2 / 3;
    background: var(--paper-deep);
    border: 1px solid var(--paper-edge);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: box-shadow 360ms ease;
  }

  .card-link:hover .cover-frame {
    box-shadow: 0 0.5px 0 var(--paper-edge), 0 26px 44px -22px rgba(28, 20, 15, 0.45);
  }

  .cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cover-placeholder {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-3);
    background:
      radial-gradient(at 30% 30%, rgba(201, 154, 74, 0.10), transparent 60%),
      linear-gradient(to bottom, var(--paper-deep), var(--paper-edge));
    color: var(--ink-soft);
  }

  .cover-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1.1;
    color: var(--ink);
    font-variation-settings: "opsz" 36, "SOFT" 50;
    letter-spacing: -0.01em;
  }

  .cover-meta {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.78rem;
    color: var(--ink-faded);
    letter-spacing: 0.04em;
  }

  .status {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    background: var(--paper);
    color: var(--ink-soft);
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.35rem 0.55rem;
    border: 1px solid var(--paper-edge);
    line-height: 1;
  }

  .status-in-progress {
    color: var(--cloth);
    border-color: var(--cloth);
  }

  .meta-block {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 400;
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -0.012em;
    font-variation-settings: "opsz" 48, "SOFT" 50;
    transition: color 200ms ease;
  }

  .card-link:hover .title {
    color: var(--lantern-deep);
  }

  .one-line {
    font-family: var(--font-body);
    color: var(--ink-soft);
    font-size: 0.98rem;
    line-height: 1.55;
    max-width: 36ch;
  }

  .open-link {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--lantern);
    border-bottom: 1px solid transparent;
    width: fit-content;
    padding-bottom: 1px;
    transition: border-color 200ms ease, color 200ms ease;
  }

  .card-link:hover .open-link {
    color: var(--lantern-deep);
    border-bottom-color: var(--lantern-deep);
  }
</style>
